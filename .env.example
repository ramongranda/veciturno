# =========================================================================
#                    🏡 VECITURNO - CONFIGURACIÓN DE ENTORNO
# =========================================================================
# Copia este archivo como .env en la raíz del proyecto para configurarlo:
# cp .env.example .env (o "copy .env.example .env" en Windows)

# Puerto en el que correrá la aplicación web (HTTP o HTTPS)
PORT=3000

# Entorno de ejecución: 'development' o 'production'
# En 'development', si no existen certificados en /certs, se autogenerarán
# automáticamente para correr en HTTPS local de forma inmediata.
NODE_ENV=development

# Clave secreta súper segura para el cifrado y firma de los JWT de sesión de vecinos
JWT_SECRET=cambiar_esta_clave_por_una_secreta_y_larga_en_produccion_2026

# Nombre oficial de la comunidad de vecinos
COMMUNITY_NAME="Comunidad de Propietarios Calle Falsa 123"

# Fecha de inicio del calendario de turnos (Formato: YYYY-MM-DD)
START_MONTH=2026-06-01

# ID de piso inicial que arranca el primer turno (por defecto '1')
START_FLOOR_ID=1

# Token de invitación inicial de un solo uso para registrar al primer administrador (Piso Piso 3/admin)
BOOTSTRAP_TOKEN="registro-inicial-planta3"

# =========================================================================
#    📱 CONFIGURACIÓN DE NOTIFICACIONES AUTO-HOSPEDADAS POR WHATSAPP
# =========================================================================
# Si usas el cliente de WhatsApp Web autohospedado integrado en segundo plano,
# no necesitas APIs externas. El sistema iniciará un Puppeteer en segundo plano
# para escanear el QR y enviar los mensajes de forma gratuita y directa.

# Opcional: URL del grupo oficial de vecinos para enviar notificaciones de rotación automáticas
NOTIFICATIONS_GROUP_URL=""

# Opcional: Teléfono o ID del grupo de WhatsApp oficial de la junta (si aplica)
SYSTEM_WHATSAPP_PHONE=""
SYSTEM_WHATSAPP_API_KEY=""
